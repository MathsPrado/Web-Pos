@page "/profile"
@attribute [Authorize]
@using Student.Web.Data
@using Student.Web.Model
@using Student.Web.Service
@inject IJSRuntime JsRuntime  
@inject PerfilUserService perfilUserService;
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject SolicitacaoProjectServer projectService
@if (perfilUser != null)
{
<h1>Profile</h1>
<link href="css/Profile.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/7.2.96Every Marketing Plan Needs/css/materialdesignicons.min.css" integrity="sha512-LX0YV/MWBEn2dwXCYgQHrpa9HJkwB+S+bnBpifSOTO1No27TqNMKYoAn6ff2FBh03THAzAiiCwQ+aPX+/Qt/Ow==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<div class="container">
    <div class="row">
        <div class="col-xl-8">
            <div class="card">
                <div class="card-body pb-0">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <div class="text-center border-end">
                                <img src="https://bootdey.com/img/Content/avatar/avatar1.png" class="img-fluid avatar-xxl rounded-circle" alt="">
                                    <h4 class="text-primary font-size-20 mt-3 mb-2">@perfilUser.Nome @perfilUser.Sobrenome</h4>
                                <h5 class="text-muted font-size-13 mb-0">Estudante / Desenvolvedor</h5>
                            </div>
                        </div><!-- end col -->
                        <div class="col-md-9">
                            <div class="ms-3">
                                <div>
                                    <h4 class="card-title mb-2">Biography</h4>

                                    @if (!string.IsNullOrEmpty(perfilUser.Biografia))
                                        {
                                        <p class="mb-0 text-muted">  </p>
                                        @perfilUser.Biografia;
                                    }
                                        else
                                        {
                                        <p class="mb-0 text-muted"> </p>
                                            <a>Hi I'm Jansh,has been the industry's standard
                                            dummy text To an English person alteration text.
                                        </a>
                                        }

                                   
                                </div>
                                <div class="row my-4">
                                    <div class="col-md-12">
                                        <div>
                                            <p class="text-muted mb-2 fw-medium">
                                                    <i class="mdi mdi-email-outline me-2"></i>@perfilUser.Email
                                            </p>
                                            <p class="text-muted fw-medium mb-0">
                                                <i class="mdi mdi-phone-in-talk-outline me-2"></i>@perfilUser.Telefone
                                            </p>
                                        </div>
                                    </div><!-- end col -->
                                </div><!-- end row -->

                                <ul class="nav nav-tabs nav-tabs-custom border-bottom-0 mt-3 nav-justfied" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <a class="nav-link px-4 active" data-bs-toggle="tab" href="#projects-tab" role="tab" aria-selected="false" tabindex="-1">
                                            <span class="d-block d-sm-none"><i class="fas fa-home"></i></span>
                                            <span class="d-none d-sm-block">Projects</span>
                                        </a>
                                    </li><!-- end li -->
                                </ul><!-- end ul -->
                            </div>
                        </div><!-- end col -->
                    </div><!-- end row -->
                </div><!-- end card body -->
            </div><!-- end card -->

            <div class="card">
                <div class="tab-content p-4">
                    <div class="tab-pane active show" id="projects-tab" role="tabpanel">
                        <div class="d-flex align-items-center">
                            <div class="flex-1">
                                <h4 class="card-title mb-4">Projects</h4>
                            </div>
                        </div>

                        <div class="row" id="all-projects">
                            @if (studentProjects != null && studentProjects.Any())
                            {
                                @foreach (var project in studentProjects)
                                {
                                    <div class="col-md-6">
                                        <div class="card mb-lg-0 mb-3">
                                            <div class="card-body">
                                                <div class="d-flex mb-3">
                                                    <div class="flex-grow-1 align-items-start">
                                                        <div>
                                                            <h6 class="mb-0 text-muted">
                                                                <i class="mdi mdi-circle-medium text-success fs-3 align-middle"></i>
                                                                <span class="team-date">@(project.DataInicio != default ? project.DataInicio.ToString("dd MMM, yyyy") : "Data não definida")</span>
                                                            </h6>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="mb-4">
                                                    <h5 class="mb-1 font-size-17 team-title">@project.Titulo</h5>
                                                    <p class="text-muted mb-0 team-description">
                                                        @project.Descricao
                                                    </p>
                                                </div>
                                            </div><!-- end cardbody -->
                                        </div><!-- end card -->
                                    </div><!-- end col -->
                                }
                            }
                            else
                            {
                                <div class="col-md-12">
                                    <p class="text-muted mt-3">Nenhum projeto associado no momento.</p>
                                </div>
                            }
                        </div><!-- end row -->
                    </div><!-- end tab pane -->






                </div>
            </div><!-- end card -->
        </div><!-- end col -->

        <div class="col-xl-4">
            <div class="card">
                <div class="card-body">
                    <div class="pb-2">
                        <h4 class="card-title mb-3">About</h4>
                        <p>
                                @perfilUser.Biografia
                        </p>
                        <ul class="ps-3 mb-0">
                            <li>PRINCIPAIS PONTOS</li>
                            @* <li>To achieve this, it would be necessary to have uniform pronunciation</li> *@
                        </ul>
                        <!-- end ul -->
                    </div>
                    <hr>
                    <div class="pt-2">
                        <h4 class="card-title mb-4">My Skill</h4>
                        <div class="d-flex gap-2 flex-wrap">
                            @if (perfilUser.Skills != null && perfilUser.Skills.Any())
                            {
                                @foreach (var skill in perfilUser.Skills)
                                {
                                    <span class="badge badge-soft-secondary p-2">@skill.Nome</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Nenhuma habilidade cadastrada.</span>
                            }
                        </div>
                    </div>
                </div><!-- end cardbody -->
            </div><!-- end card -->

            <div class="card">
                <div class="card-body">
                    <div>
                        <h4 class="card-title mb-4">Personal Details</h4>
                        <div class="table-responsive">
                            <table class="table table-bordered mb-0">
                                <tbody>
                                    <tr>
                                        <th scope="row">Name</th>
                                        <td>@perfilUser.Nome @perfilUser.Sobrenome</td>
                                    </tr><!-- end tr -->
                                    <tr>
                                        <th scope="row">Email</th>
                                        <td>@perfilUser.Email</td>
                                    </tr><!-- end tr -->
                                    <tr>
                                        <th scope="row">Phone</th>
                                        <td>@perfilUser.Telefone</td>
                                    </tr><!-- end tr -->
                                </tbody><!-- end tbody -->
                            </table><!-- end table -->
                        </div>
                    </div>
                </div><!-- end card body -->
            </div><!-- end card -->

            <div class="card">
                <div class="card-body">
                    <div>
                        <h4 class="card-title mb-4">Work Experince</h4>
                        <ul class="list-unstyled work-activity mb-0">
                            @if (perfilUser.Experiences != null && perfilUser.Experiences.Any())
                            {
                                @foreach (var exp in perfilUser.Experiences)
                                {
                                    <li class="work-item" data-date="@exp.DataInicioFim">
                                        <h6 class="lh-base mb-0">@exp.Empresa</h6>
                                        <p class="font-size-13 mb-2">@exp.Cargo</p>
                                        <p class="mb-0">@exp.Descricao</p>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="text-muted">Nenhuma experi�ncia profissional cadastrada.</li>
                            }
                        </ul><!-- end ul -->
                    </div>
                </div><!-- end card-body -->
            </div><!-- end card -->
        </div><!-- end col -->
    </div>
    </div>
}
else
{
    <h1>Loading...</h1>
}

@code {

    private PerfilUser perfilUser = new PerfilUser();
    private IEnumerable<SolicitacaoProjeto> studentProjects = new List<SolicitacaoProjeto>();
    int a = 0;
    protected override async Task OnInitializedAsync()
    {
        System.Console.WriteLine("[DIAG RAZOR] OnInitializedAsync started");
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            System.Console.WriteLine($"[DIAG RAZOR] User Identity: {user?.Identity?.Name}, IsAuthenticated: {user?.Identity?.IsAuthenticated}");
            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                var role = user.FindFirst("role")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                if (string.Equals(role, "Company", StringComparison.OrdinalIgnoreCase))
                {
                    NavigationManager.NavigateTo("company-profile");
                    return;
                }

                var email = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value 
                            ?? user.FindFirst("unique_name")?.Value 
                            ?? user.FindFirst("email")?.Value 
                            ?? user.Identity.Name;
                if (!string.IsNullOrEmpty(email))
                {
                    var fetchedUser = await perfilUserService.FindByEmail(email);
                    if (fetchedUser != null)
                    {
                        perfilUser = fetchedUser;
                        System.Console.WriteLine($"[DIAG] Fetched email: {email}");
                        System.Console.WriteLine($"[DIAG] Skills count: {perfilUser.Skills?.Count ?? -1}");
                        System.Console.WriteLine($"[DIAG] Experiences count: {perfilUser.Experiences?.Count ?? -1}");
                        
                        if (perfilUser.Id > 0)
                        {
                            studentProjects = await projectService.GetProjetosByUsuario(perfilUser.Id);
                        }
                    }
                }
            }
        }
        catch (Exception e)
        {
            var testeErro = e.Message;
        }
    }
}
