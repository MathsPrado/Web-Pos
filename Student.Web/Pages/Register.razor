@page "/register"
@layout LoginLayout
@using MeuProjetoBlazor.Models
@using MeuProjetoBlazor.Services
@using Student.Web.Model
@using Student.Web.Service
@inject IAuthService AuthService
@inject NavigationManager NavManager

<div class="login-card">
    <div class="login-header">
        <div class="brand-logo-container">
            <i class="bi bi-person-plus-fill brand-logo-icon"></i>
        </div>
        <h2 class="brand-main-title">StudentFreela</h2>
        <h3>Crie sua Conta</h3>
        <p>Preencha os campos abaixo de cadastro</p>
    </div>

    <div class="login-body">
        <div class="form-group mb-2">
            <label class="form-label">Nome</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input class="form-control" @bind="registerRequest.Nome" placeholder="Digite seu nome" />
            </div>
        </div>

        <div class="form-group mb-2">
            <label class="form-label">Tipo de Perfil</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-people-fill"></i></span>
                <select class="form-control" @bind="registerRequest.Role" style="background-color: white;">
                    <option value="User">Estudante (Freelancer)</option>
                    <option value="Company">Empresa Parceira</option>
                </select>
            </div>
        </div>

        @if (registerRequest.Role != "Company")
        {
            <div class="form-group mb-2">
                <label class="form-label">Sobrenome</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input class="form-control" @bind="registerRequest.Sobrenome" placeholder="Digite seu sobrenome" />
                </div>
            </div>
        }

        <div class="form-group mb-2">
            <label class="form-label">E-mail</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                <input type="email" class="form-control" @bind="registerRequest.Email" placeholder="exemplo@freela.com" />
            </div>
        </div>

        <div class="form-group mb-3">
            <label class="form-label">Senha</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                <input type="password" class="form-control" @bind="registerRequest.Password" placeholder="Crie uma senha" />
            </div>
        </div>

        <button class="btn-login" @onclick="HandleRegister" disabled="@isLoading">
            @if (isLoading)
            {
                <span>Processando...</span>
            }
            else
            {
                <span>Cadastrar</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert-error">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @errorMsg
            </div>
        }

        <div class="mt-3 text-center signup-prompt">
            <span>Já possui uma conta?</span>
            <a href="login" class="ms-1 signup-link">Faça Login</a>
        </div>
    </div>
</div>

<style>
/* Light Elegance Compact Card Style */
.login-card {
    background: #ffffff;
    border: 1px solid rgba(75, 27, 138, 0.08);
    padding: 1.5rem 2rem; /* Reduzido significativamente */
    border-radius: 16px;
    box-shadow: 0 15px 35px rgba(75, 27, 138, 0.06);
    width: 100%;
    max-width: 400px;
    text-align: center;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}

/* Brand Logo */
.brand-logo-container {
    width: 42px; /* Reduzido de 60px/45px */
    height: 42px; /* Reduzido de 60px/45px */
    background: rgba(75, 27, 138, 0.05);
    border: 1px solid rgba(75, 27, 138, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.4rem auto;
}

.brand-logo-icon {
    font-size: 1.2rem;
    color: #4b1b8a;
}

.brand-main-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: #4b1b8a;
    margin-bottom: 0.1rem;
    letter-spacing: 0.5px;
}

/* Header Text */
.login-header h3 {
    color: #333333;
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 0.2rem;
}

.login-header p {
    color: #695e78;
    font-size: 0.8rem;
    margin-bottom: 1.2rem;
}

/* Inputs & Labels */
.form-group {
    text-align: left;
}

.form-label {
    display: block;
    margin-bottom: 0.25rem;
    color: #453c52;
    font-weight: 600;
    font-size: 0.8rem;
}

.input-group {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #dcdbe0;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #ffffff;
}

.input-group:focus-within {
    border-color: #4b1b8a;
    box-shadow: 0 0 8px rgba(75, 27, 138, 0.15);
}

.input-group-text {
    background: #f5f4f7 !important;
    border: none !important;
    color: #695e78 !important;
    padding: 8px 12px !important; /* Mais compacto */
    display: flex;
    align-items: center;
}

.form-control {
    background: transparent !important;
    border: none !important;
    color: #333333 !important;
    padding: 8px 10px; /* Reduzido de 11px 12px */
    font-size: 0.9rem;
    box-sizing: border-box;
}

.form-control::placeholder {
    color: #a9a2b5;
}

.form-control:focus {
    box-shadow: none !important;
    outline: none !important;
}

/* Botão Gradiente Premium */
.btn-login {
    width: 100%;
    padding: 10px 12px; /* Reduzido de 13px */
    background: linear-gradient(135deg, #6222b5 0%, #4b1b8a 100%);
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 12px rgba(75, 27, 138, 0.25);
    margin-top: 0.4rem;
}

.btn-login:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(75, 27, 138, 0.35);
    opacity: 0.95;
}

.btn-login:disabled {
    background: #e2e1e6;
    color: #a9a2b5;
    box-shadow: none;
    cursor: not-allowed;
    transform: none;
}

/* Erro Alert */
.alert-error {
    margin-top: 0.8rem;
    padding: 8px 10px;
    background-color: #fee2e2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    border-radius: 6px;
    font-size: 0.8rem;
    text-align: left;
    display: flex;
    align-items: center;
}

/* Prompts */
.signup-prompt {
    font-size: 0.8rem;
    color: #695e78;
}

.signup-link {
    color: #4b1b8a;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
}

.signup-link:hover {
    color: #1a082e;
    text-decoration: underline;
}
</style>

@code {
    private RegisterRequest registerRequest = new();
    private string errorMsg;
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(registerRequest.Nome) ||
            (registerRequest.Role != "Company" && string.IsNullOrWhiteSpace(registerRequest.Sobrenome)) ||
            string.IsNullOrWhiteSpace(registerRequest.Email) ||
            string.IsNullOrWhiteSpace(registerRequest.Password))
        {
            errorMsg = "Preencha todos os campos do formulário.";
            return;
        }

        isLoading = true;
        errorMsg = null;
        StateHasChanged();

        try
        {
            var sucesso = await AuthService.Register(registerRequest);

            if (sucesso)
            {
                NavManager.NavigateTo("/"); // Registro feito com sucesso redireciona para a Home logada
            }
            else
            {
                errorMsg = "Erro ao realizar cadastro. E-mail já registrado ou dados inválidos.";
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Erro ao se comunicar: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
